{
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix functions run build"
    ]
  },
  "hosting": {
    "public": "web/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/google-ads/oauth-start",
        "function": "googleAdsOAuthStart"
      },
      {
        "source": "/api/google-ads/oauth-callback",
        "function": "googleAdsOAuthCallback"
      },
      {
        "source": "/api/google-ads/campaign",
        "function": "googleAdsCampaign"
      },
      {
        "source": "/api/google-ads/metrics-sync",
        "function": "googleAdsMetricsSync"
      },
      {
        "source": "/api/google-business/locations",
        "function": "googleBusinessLocations"
      },
      {
        "source": "/api/google-business/upload-location-media",
        "function": "googleBusinessUploadLocationMedia"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": [
    {
      "database": "(default)",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    },
    {
      "database": "roster",
      "rules": "firestore.roster.rules",
      "indexes": "firestore.roster.indexes.json"
    }
  ],
  "emulators": {
    "functions": {
      "port": 5001
    },
    "firestore": {
      "port": 8080
    }
  }
}
